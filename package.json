{
  "name": "symbol-doc-lens",
  "displayName": "Symbol Doc Lens",
  "description": "Show symbol documentation inline at reference sites.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onCommand:symbolDocLens.toggle",
    "onCommand:symbolDocLens.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "symbolDocLens.toggle",
        "title": "Symbol Doc Lens: Toggle"
      },
      {
        "command": "symbolDocLens.refresh",
        "title": "Symbol Doc Lens: Refresh"
      }
    ],
    "configuration": {
      "title": "Symbol Doc Lens",
      "properties": {
        "symbolDocLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Symbol Doc Lens inlay hints."
        },
        "symbolDocLens.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "go",
            "typescript",
            "javascript",
            "typescriptreact",
            "javascriptreact"
          ],
          "description": "Language identifiers where Symbol Doc Lens runs."
        },
        "symbolDocLens.maxHintLength": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "description": "Maximum length of the inline comment summary."
        },
        "symbolDocLens.maxHintsPerRequest": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "Maximum number of hints produced per inlay hint request."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node --test out/test/*.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.5.2"
  }
}
